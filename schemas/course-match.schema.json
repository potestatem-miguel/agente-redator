{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "course_match",
  "type": "object",
  "required": ["courses", "internal_links"],
  "properties": {
    "courses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "id": { "type": ["number", "null"] },
          "slug": { "type": ["string", "null"] },
          "title": { "type": ["string", "null"] },
          "url": { "type": "string" },
          "anchor": { "type": ["string", "null"] },
          "reason": { "type": ["string", "null"] },
          "score": { "type": ["number", "null"] }
        }
      }
    },
    "internal_links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": { "type": "string" },
          "anchor": { "type": ["string", "null"] }
        }
      }
    },
    "debug": {
      "type": "object",
      "properties": {
        "query_text": { "type": "string" },
        "limit": { "type": "number" }
      }
    },
    "error": { "type": ["string", "null"] }
  }
}
